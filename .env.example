# LogScale instance URL (required)
# Include path prefix if your instance serves API under a subpath (e.g., /logs)
LOGSCALE_BASE_URL=https://your-logscale-instance.com/logs

# Bearer token for API authentication (required)
LOGSCALE_API_TOKEN=your-api-token-here

# Default repository name (can be this or it can be specified per-query also) (required)
LOGSCALE_REPOSITORY=your-repository-name

# Max time to wait for query completion in ms (optional, default: 60000)
LOGSCALE_TIMEOUT_MS=60000

# Interval between poll requests in ms (optional, default: 1000)
LOGSCALE_POLL_INTERVAL_MS=1000

# Default max events per query (optional, default: 200, max: 500)
LOGSCALE_MAX_EVENTS=200
