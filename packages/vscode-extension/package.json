{
  "name": "logscale-mcp-vscode",
  "displayName": "LogScale(Humio) MCP Server",
  "description": "VS Code extension that provides an MCP server for querying CrowdStrike Falcon LogScale formerly Humio logs",
  "version": "0.1.6",
  "publisher": "bhayanak",
  "icon": "logo.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhayanak/logscale-mcp-server"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "mcp server",
    "logscale",
    "crowdstrike",
    "cql",
    "logs",
    "ai",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "LogScale MCP Server",
      "properties": {
        "logscale.servers": {
          "type": "array",
          "description": "Multiple LogScale server configurations. Each entry needs a name, baseUrl, apiToken, and optional repository.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "baseUrl",
              "apiToken"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Short name for this server (e.g., 'scdev01', 'hcipoc01')"
              },
              "baseUrl": {
                "type": "string",
                "description": "LogScale instance URL (include path prefix like /logs if needed)"
              },
              "apiToken": {
                "type": "string",
                "description": "API token for this server"
              },
              "repository": {
                "type": "string",
                "description": "Default repository for this server"
              }
            }
          },
          "default": [],
          "order": 0
        },
        "logscale.apiToken": {
          "type": "string",
          "description": "LogScale API token for authentication (single-server mode, used as 'default' server)",
          "order": 1
        },
        "logscale.baseUrl": {
          "type": "string",
          "description": "LogScale instance URL — single-server mode (include path prefix like /logs if needed)",
          "order": 2
        },
        "logscale.repository": {
          "type": "string",
          "description": "Default LogScale repository name (single-server mode)",
          "order": 3
        },
        "logscale.timeoutMs": {
          "type": "number",
          "default": 60000,
          "description": "Maximum query poll timeout in milliseconds"
        },
        "logscale.pollIntervalMs": {
          "type": "number",
          "default": 1000,
          "description": "Interval between poll requests in milliseconds"
        },
        "logscale.maxEvents": {
          "type": "number",
          "default": 200,
          "description": "Default pagination limit for events"
        }
      }
    },
    "commands": [
      {
        "command": "logscale-mcp.showHealth",
        "title": "LogScale MCP: Show Server Health"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "logscale-mcp",
        "label": "LogScale"
      }
    ]
  },
  "scripts": {
    "build": "node build.cjs",
    "watch": "node build.cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --check \"src/**/*.ts\"",
    "validate": "tsc --noEmit",
    "package": "node build.cjs && vsce package --no-dependencies --allow-missing-repository --skip-license",
    "ci": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "logscale-mcp-server": "workspace:*"
  }
}
